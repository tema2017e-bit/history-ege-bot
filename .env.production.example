# =====================================================
# Production environment for History EGE Bot
# Скопируйте в .env перед запуском docker-compose
# =====================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=ваш_токен_бота_от_BotFather
BOT_USERNAME=history_ege_bot

# --- Mini App ---
MINI_APP_URL=https://history-ege.vercel.app

# --- Админ ---
ADMIN_ID=ваш_telegram_chat_id
ADMIN_API_SECRET=придумайте_секретную_строку

# --- База данных ---
DB_PASSWORD=придумайте_пароль_для_postgres
DATABASE_URL=postgresql://history_ege:${DB_PASSWORD}@localhost:5432/history_ege

# --- ЮKassa ---
YUKASSA_SHOP_ID=ваш_shop_id
YUKASSA_SECRET_KEY=ваш_секретный_ключ

# --- Внешний URL (для вебхуков) ---
# Если на VPS — http://ваш-сервер:3000
# Если через reverse proxy — https://ваш-домен
EXTERNAL_URL=https://ваш-сервер:3000